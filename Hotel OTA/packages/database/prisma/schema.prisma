generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────

enum UserTier {
  basic
  silver
  gold
}

enum AttributionSource {
  ota_app
  rez_app
  corporate
  hotel_qr
  seo
  direct
}

enum HotelCategory {
  budget
  midscale
  upscale
  boutique
  serviced_apartment
}

enum OnboardingStatus {
  pending
  active
  suspended
  churned
}

enum ChannelSource {
  ota_app
  rez_app
  corporate
  hotel_qr
}

enum BookingStatus {
  init
  hold
  confirmed
  checked_in
  stayed
  cancelled
  no_show
  completed
}

enum PaymentStatus {
  pending
  paid
  refunded
  partial_refund
}

enum PaymentMethod {
  upi
  card
  netbanking
  ota_wallet
  rez_wallet
  corporate_credit
}

enum RefundStatus {
  not_applicable
  pending
  processed
}

enum BookingEventType {
  created
  hold_placed
  confirmed
  payment_received
  checked_in
  stayed
  cancelled
  refunded
  coin_earned
  coin_burned
  mining_triggered
  settlement_triggered
}

enum EventTriggeredBy {
  user
  system
  admin
  rez_webhook
}

enum CoinType {
  ota
  rez
  hotel_brand
}

enum CoinTransactionType {
  earn
  burn
  expire
  refund_credit
  admin_adjust
  earn_reversal
}

enum CoinDirection {
  credit
  debit
}

enum EarnRuleChannel {
  ota_app
  rez_app
  corporate
  hotel_qr
  all
}

enum EarnRuleTier {
  basic
  silver
  gold
  all
}

enum SettlementStatus {
  pending
  approved
  paid
  disputed
  cancelled
}

enum PayoutBatchStatus {
  processing
  completed
  failed
}

enum CoinExpiryStatus {
  pending
  expired
  used
}

// ─── PHASE 1: CORE TABLES ──────────────────────────────────

model User {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone               String            @unique @db.VarChar(15)
  email               String?           @unique @db.VarChar(255)
  fullName            String?           @map("full_name") @db.VarChar(255)
  profilePhotoUrl     String?           @map("profile_photo_url")
  tier                UserTier          @default(basic)
  rezUserId           String?           @map("rez_user_id") @db.VarChar(255)
  attributionSource   AttributionSource @default(ota_app) @map("attribution_source")
  attributionPartner  String?           @map("attribution_partner") @db.VarChar(50)
  attributionExpiryTs DateTime?         @map("attribution_expiry_ts") @db.Timestamptz()
  lastCampaignClickTs DateTime?         @map("last_campaign_click_ts") @db.Timestamptz()
  lastCampaignId      String?           @map("last_campaign_id") @db.VarChar(100)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz()
  isActive            Boolean           @default(true) @map("is_active")
  fcmToken            String?           @map("fcm_token")

  bookings                Booking[]
  coinWallet              CoinWallet?
  coinTransactions        CoinTransaction[]
  coinExpirySchedules     CoinExpirySchedule[]
  stayRegistrations       StayRegistration[]
  attributionLogs         AttributionLog[]
  offlinePayments         OfflinePayment[]
  corporateUsers          CorporateUser[]
  referralsMade           Referral[]                    @relation("referrer")
  referralsReceived       Referral[]                    @relation("referred")
  reviews                 Review[]
  wishlists               Wishlist[]
  hotelBrandCoinBalances  HotelBrandCoinBalance[]
  bookingCoinTransactions HotelBookingCoinTransaction[]

  @@map("users")
}

model Hotel {
  id                           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                         String           @db.VarChar(255)
  slug                         String           @unique @db.VarChar(255)
  legalName                    String?          @map("legal_name") @db.VarChar(255)
  gstin                        String?          @db.VarChar(15)
  pan                          String?          @db.VarChar(10)
  addressLine1                 String?          @map("address_line1") @db.VarChar(255)
  addressLine2                 String?          @map("address_line2") @db.VarChar(255)
  city                         String           @default("Bangalore") @db.VarChar(100)
  pincode                      String?          @db.VarChar(10)
  latitude                     Decimal?         @db.Decimal(10, 7)
  longitude                    Decimal?         @db.Decimal(10, 7)
  starRating                   Int?             @map("star_rating") @db.SmallInt
  category                     HotelCategory?
  description                  String?
  amenities                    Json?            @db.JsonB
  images                       Json?            @db.JsonB
  primaryContactName           String?          @map("primary_contact_name") @db.VarChar(255)
  primaryContactPhone          String?          @map("primary_contact_phone") @db.VarChar(15)
  primaryContactEmail          String?          @map("primary_contact_email") @db.VarChar(255)
  bankAccountNumber            String?          @map("bank_account_number") @db.VarChar(50)
  bankIfsc                     String?          @map("bank_ifsc") @db.VarChar(11)
  bankAccountName              String?          @map("bank_account_name") @db.VarChar(255)
  onboardingStatus             OnboardingStatus @default(pending) @map("onboarding_status")
  participationAgreementSigned Boolean          @default(false) @map("participation_agreement_signed")
  participationAgreementDate   DateTime?        @map("participation_agreement_date") @db.Date
  otaCommissionPct             Decimal          @default(6.00) @map("ota_commission_pct") @db.Decimal(4, 2)
  miningEligible               Boolean          @default(true) @map("mining_eligible")
  brandCoinEnabled             Boolean          @default(false) @map("brand_coin_enabled")
  brandCoinName                String?          @map("brand_coin_name") @db.VarChar(100)
  brandCoinSymbol              String?          @map("brand_coin_symbol") @db.VarChar(20)
  pmsWebhookUrl                String?          @map("pms_webhook_url") @db.VarChar(500)
  pmsWebhookSecret             String?          @map("pms_webhook_secret") @db.VarChar(255)
  pmsWebhookActive             Boolean          @default(false) @map("pms_webhook_active")
  pmsWebhookLastTriggeredAt    DateTime?        @map("pms_webhook_last_triggered_at") @db.Timestamptz()
  pmsWebhookErrorCount         Int              @default(0) @map("pms_webhook_error_count")
  hotelId                      String?          @unique @map("hotel_id") @db.Uuid
  createdAt                    DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                    DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  roomTypes               RoomType[]
  rooms                   Room[]
  inventorySlots          InventorySlot[]
  bookings                Booking[]
  hotelWallet             HotelWallet?
  settlementEntries       SettlementEntry[]
  earnRules               EarnRule[]
  stayRegistrations       StayRegistration[]
  contributionScores      HotelContributionScore[]
  ownershipTokens         OwnershipTokenLedger[]
  vestingSchedules        VestingSchedule[]
  offlinePayments         OfflinePayment[]
  apiKeys                 HotelApiKey[]
  channelManagerConfigs   ChannelManagerConfig[]
  seoLandingPages         SeoLandingPage[]
  pricingSuggestions      PricingSuggestion[]
  demandForecasts         DemandForecast[]
  miningDisputes          MiningDispute[]
  reviews                 Review[]
  wishlists               Wishlist[]
  brandCoinBalances       HotelBrandCoinBalance[]
  brandCoinTransactions   CoinTransaction[]             @relation("BrandCoinTransactions")
  coinExpirySchedules     CoinExpirySchedule[]          @relation("ExpiryScheduleHotel")
  pmsWebhookEvents        PmsWebhookEvent[]
  bookingCoinTransactions HotelBookingCoinTransaction[]
  RoomServiceRequest      RoomServiceRequest[]
  hotelStaffInvite       StaffInvite[]

  @@map("hotels")
}

model RoomType {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId       String   @map("hotel_id") @db.Uuid
  name          String   @db.VarChar(255)
  description   String?
  maxOccupancy  Int      @default(2) @map("max_occupancy") @db.SmallInt
  bedType       String?  @map("bed_type") @db.VarChar(100)
  sizeSqft      Int?     @map("size_sqft") @db.SmallInt
  amenities     Json?    @db.JsonB
  images        Json?    @db.JsonB
  baseRatePaise Int      @map("base_rate_paise")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  hotel              Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  inventorySlots     InventorySlot[]
  bookings           Booking[]
  pricingSuggestions PricingSuggestion[]
  rooms              Room[]

  @@map("room_types")
}

model InventorySlot {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId        String   @map("hotel_id") @db.Uuid
  roomTypeId     String   @map("room_type_id") @db.Uuid
  date           DateTime @db.Date
  totalRooms     Int      @map("total_rooms") @db.SmallInt
  availableRooms Int      @map("available_rooms") @db.SmallInt
  ratePaise      Int      @map("rate_paise")
  minStayNights  Int      @default(1) @map("min_stay_nights") @db.SmallInt
  isBlocked      Boolean  @default(false) @map("is_blocked")
  blockReason    String?  @map("block_reason") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  hotel    Hotel    @relation(fields: [hotelId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, date])
  @@index([hotelId, date])
  @@index([roomTypeId, date, availableRooms])
  @@map("inventory_slots")
}

model Booking {
  id                          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingRef                  String         @unique @map("booking_ref") @db.VarChar(20)
  userId                      String         @map("user_id") @db.Uuid
  hotelId                     String         @map("hotel_id") @db.Uuid
  roomTypeId                  String         @map("room_type_id") @db.Uuid
  channelSource               ChannelSource  @map("channel_source")
  attributionPartner          String?        @map("attribution_partner") @db.VarChar(50)
  campaignId                  String?        @map("campaign_id") @db.VarChar(100)
  checkinDate                 DateTime       @map("checkin_date") @db.Date
  checkoutDate                DateTime       @map("checkout_date") @db.Date
  checkIn                     DateTime?      @map("check_in") @db.Timestamptz()
  checkOut                    DateTime?      @map("check_out") @db.Timestamptz()
  numNights                   Int            @map("num_nights") @db.SmallInt
  numRooms                    Int            @default(1) @map("num_rooms") @db.SmallInt
  numGuests                   Int            @default(1) @map("num_guests") @db.SmallInt
  guestName                   String?        @map("guest_name") @db.VarChar(255)
  guestPhone                  String?        @map("guest_phone") @db.VarChar(15)
  specialRequests             String?        @map("special_requests")
  roomRatePaise               Int            @map("room_rate_paise")
  totalValuePaise             Int            @map("total_value_paise")
  otaCommissionPaise          Int            @map("ota_commission_paise")
  otaCoinBurnedPaise          Int            @default(0) @map("ota_coin_burned_paise")
  rezCoinBurnedPaise          Int            @default(0) @map("rez_coin_burned_paise")
  hotelBrandCoinBurnedPaise   Int            @default(0) @map("hotel_brand_coin_burned_paise")
  pgAmountPaise               Int            @map("pg_amount_paise")
  paymentStatus               PaymentStatus  @default(pending) @map("payment_status")
  paymentMethod               PaymentMethod? @map("payment_method")
  razorpayOrderId             String?        @map("razorpay_order_id") @db.VarChar(255)
  razorpayPaymentId           String?        @map("razorpay_payment_id") @db.VarChar(255)
  status                      BookingStatus  @default(init)
  cancellationReason          String?        @map("cancellation_reason")
  cancelledAt                 DateTime?      @map("cancelled_at") @db.Timestamptz()
  deletedAt                   DateTime?      @map("deleted_at") @db.Timestamptz() // M-1: Soft delete for GDPR/data retention
  refundAmountPaise           Int            @default(0) @map("refund_amount_paise")
  cancellationPenaltyPaise    Int            @default(0) @map("cancellation_penalty_paise")
  refundStatus                RefundStatus   @default(not_applicable) @map("refund_status")
  stayCompletedFlag           Boolean        @default(false) @map("stay_completed_flag")
  stayCompletedAt             DateTime?      @map("stay_completed_at") @db.Timestamptz()
  holdExpiresAt               DateTime?      @map("hold_expires_at") @db.Timestamptz()
  // BUG-20: Mining eligibility snapshot — stores the hotel's mining eligibility
  // at the time of booking confirmation to prevent rule changes from affecting past bookings
  miningEligible              Boolean        @default(false) @map("mining_eligible")
  miningRulesVersion          String         @default("v1") @map("mining_rules_version") @db.VarChar(20)
  miningEligibilitySnapshotAt DateTime?      @map("mining_eligibility_snapshot_at") @db.Timestamptz()
  createdAt                   DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                   DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  user               User                 @relation(fields: [userId], references: [id])
  hotel              Hotel                @relation(fields: [hotelId], references: [id])
  roomType           RoomType             @relation(fields: [roomTypeId], references: [id])
  bookingEvents      BookingEvent[]
  coinTransactions   CoinTransaction[]
  settlementEntry    SettlementEntry?
  attributionLogs    AttributionLog[]
  rezBookingSyncs    RezBookingSync[]
  review             Review?
  corporateAccount   CorporateAccount?    @relation(fields: [corporateAccountId], references: [id])
  corporateAccountId String?              @map("corporate_account_id") @db.Uuid
  refunds            Refund[]
  RoomServiceRequest RoomServiceRequest[]

  @@index([userId, createdAt])
  @@index([hotelId, checkinDate])
  @@index([status, checkinDate])
  @@index([channelSource, attributionPartner])
  @@map("bookings")
}

model BookingEvent {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId   String           @map("booking_id") @db.Uuid
  eventType   BookingEventType @map("event_type")
  eventData   Json?            @map("event_data") @db.JsonB
  triggeredBy EventTriggeredBy @map("triggered_by")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@index([bookingId, eventType]) // M-2: Index for event type queries by booking
  @@map("booking_events")
}

// ─── PHASE 1: COIN SYSTEM ──────────────────────────────────

model CoinWallet {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                     String    @unique @map("user_id") @db.Uuid
  otaCoinBalancePaise        Int       @default(0) @map("ota_coin_balance_paise")
  otaCoinLifetimeEarnedPaise Int       @default(0) @map("ota_coin_lifetime_earned_paise")
  otaCoinLifetimeBurnedPaise Int       @default(0) @map("ota_coin_lifetime_burned_paise")
  rezCoinBalancePaise        Int       @default(0) @map("rez_coin_balance_paise")
  hotelCoinsEarned           Int       @default(0) @map("hotel_coins_earned")
  hotelCoinsSpent            Int       @default(0) @map("hotel_coins_spent")
  coinExpiry                 DateTime? @map("coin_expiry") @db.Timestamptz()
  expiringCoins              Int       @default(0) @map("expiring_coins")
  updatedAt                  DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  user                User                          @relation(fields: [userId], references: [id])
  coinTransactions    CoinTransaction[]
  expiryNotifications HotelCoinExpiryNotification[]

  @@map("coin_wallets")
}

model CoinTransaction {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String              @map("user_id") @db.Uuid
  walletId          String              @map("wallet_id") @db.Uuid
  coinType          CoinType            @map("coin_type")
  transactionType   CoinTransactionType @map("transaction_type")
  amountPaise       Int                 @map("amount_paise")
  direction         CoinDirection
  bookingId         String?             @map("booking_id") @db.Uuid
  earnRuleId        String?             @map("earn_rule_id") @db.Uuid
  hotelId           String?             @map("hotel_id") @db.Uuid
  expiryDate        DateTime?           @map("expiry_date") @db.Date
  balanceAfterPaise Int                 @map("balance_after_paise")
  notes             String?
  idempotencyKey    String?             @map("idempotency_key") @db.VarChar(255)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  user       User       @relation(fields: [userId], references: [id])
  wallet     CoinWallet @relation(fields: [walletId], references: [id])
  booking    Booking?   @relation(fields: [bookingId], references: [id])
  earnRule   EarnRule?  @relation(fields: [earnRuleId], references: [id])
  brandHotel Hotel?     @relation("BrandCoinTransactions", fields: [hotelId], references: [id])

  coinExpirySchedules CoinExpirySchedule[]

  @@index([userId, coinType, createdAt])
  @@index([expiryDate])
  @@index([idempotencyKey])
  @@map("coin_transactions")
}

model EarnRule {
  id                     String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleName               String          @map("rule_name") @db.VarChar(255)
  coinType               CoinType        @map("coin_type")
  channelSource          EarnRuleChannel @default(all) @map("channel_source")
  hotelId                String?         @map("hotel_id") @db.Uuid
  userTier               EarnRuleTier    @default(all) @map("user_tier")
  campaignId             String?         @map("campaign_id") @db.VarChar(100)
  earnPct                Decimal         @map("earn_pct") @db.Decimal(5, 2)
  minBookingValuePaise   Int             @default(0) @map("min_booking_value_paise")
  maxEarnPerBookingPaise Int?            @map("max_earn_per_booking_paise")
  validFrom              DateTime        @map("valid_from") @db.Date
  validUntil             DateTime?       @map("valid_until") @db.Date
  isActive               Boolean         @default(true) @map("is_active")
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  hotel            Hotel?            @relation(fields: [hotelId], references: [id])
  coinTransactions CoinTransaction[]

  @@map("earn_rules")
}

model BurnRule {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coinType   CoinType     @map("coin_type")
  userTier   EarnRuleTier @default(all) @map("user_tier")
  hotelId    String?      @map("hotel_id") @db.Uuid
  maxBurnPct Decimal      @map("max_burn_pct") @db.Decimal(5, 2)
  minCashPct Decimal      @default(0.00) @map("min_cash_pct") @db.Decimal(5, 2)
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  @@map("burn_rules")
}

model CoinExpirySchedule {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  coinType            CoinType         @map("coin_type")
  hotelId             String?          @map("hotel_id") @db.Uuid
  amountPaise         Int              @map("amount_paise")
  expiryDate          DateTime         @map("expiry_date") @db.Date
  sourceTransactionId String           @map("source_transaction_id") @db.Uuid
  status              CoinExpiryStatus @default(pending)
  processedAt         DateTime?        @map("processed_at") @db.Timestamptz()

  user              User            @relation(fields: [userId], references: [id])
  sourceTransaction CoinTransaction @relation(fields: [sourceTransactionId], references: [id])
  hotel             Hotel?          @relation("ExpiryScheduleHotel", fields: [hotelId], references: [id])

  @@index([expiryDate, status])
  @@map("coin_expiry_schedule")
}

model HotelBrandCoinBalance {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  hotelId             String   @map("hotel_id") @db.Uuid
  balancePaise        Int      @default(0) @map("balance_paise")
  lifetimeEarnedPaise Int      @default(0) @map("lifetime_earned_paise")
  lifetimeBurnedPaise Int      @default(0) @map("lifetime_burned_paise")
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id])
  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([userId, hotelId])
  @@index([userId])
  @@map("hotel_brand_coin_balances")
}

// ─── PHASE 1: HOTEL SETTLEMENT ─────────────────────────────

model HotelWallet {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId               String   @unique @map("hotel_id") @db.Uuid
  availableBalancePaise Int      @default(0) @map("available_balance_paise")
  pendingBalancePaise   Int      @default(0) @map("pending_balance_paise")
  lifetimeEarnedPaise   Int      @default(0) @map("lifetime_earned_paise")
  lifetimeSettledPaise  Int      @default(0) @map("lifetime_settled_paise")
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_wallets")
}

model SettlementEntry {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotelId            String           @map("hotel_id") @db.Uuid
  bookingId          String           @unique @map("booking_id") @db.Uuid
  grossAmountPaise   Int              @map("gross_amount_paise")
  commissionPaise    Int              @map("commission_paise")
  coinLiabilityPaise Int              @default(0) @map("coin_liability_paise")
  netPayablePaise    Int              @map("net_payable_paise")
  status             SettlementStatus @default(pending)
  payoutBatchId      String?          @map("payout_batch_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  hotel       Hotel        @relation(fields: [hotelId], references: [id])
  booking     Booking      @relation(fields: [bookingId], references: [id])
  payoutBatch PayoutBatch? @relation(fields: [payoutBatchId], references: [id])

  @@map("settlement_entries")
}

model PayoutBatch {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchRef         String            @unique @map("batch_ref") @db.VarChar(50)
  totalHotels      Int               @map("total_hotels")
  totalAmountPaise Int               @map("total_amount_paise")
  status           PayoutBatchStatus @default(processing)
  razorpayPayoutId String?           @map("razorpay_payout_id") @db.VarChar(255)
  initiatedAt      DateTime          @default(now()) @map("initiated_at") @db.Timestamptz()
  completedAt      DateTime?         @map("completed_at") @db.Timestamptz()

  settlementEntries SettlementEntry[]

  @@map("payout_batches")
}

// ─── OTP STORAGE ────────────────────────────────────────────

model OtpRecord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String   @db.VarChar(15)
  otpHash   String   @map("otp_hash")
  otpRef    String   @unique @map("otp_ref") @db.VarChar(50)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([phone, createdAt])
  @@map("otp_records")
}

// ─── ADMIN USERS ────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
