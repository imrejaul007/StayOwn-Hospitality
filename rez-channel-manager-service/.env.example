# ===========================================
# Channel Manager Service - Environment Configuration
# ===========================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT THE .env FILE TO VERSION CONTROL

# ===========================================
# Server Configuration
# ===========================================
PORT=4006
NODE_ENV=development

# ===========================================
# Database (MongoDB) - REQUIRED
# ===========================================
MONGODB_URI=mongodb://localhost:27017/rez-channel-manager

# ===========================================
# Redis (for rate limiting and locks)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Internal Service Communication - REQUIRED
# ===========================================
# JSON map of service names to secure tokens
# Generate tokens: openssl rand -hex 32
# Example: {"pms-service":"<token1>","payment-service":"<token2>"}
INTERNAL_SERVICE_TOKENS_JSON=

# ===========================================
# Channel API Credentials
# ===========================================
# Booking.com
BOOKINGCOM_API_KEY=
BOOKINGCOM_API_SECRET=
BOOKINGCOM_PROPERTY_ID=

# Airbnb
AIRBNB_API_KEY=
AIRBNB_PROPERTY_ID=

# Agoda
AGODA_API_KEY=
AGODA_PROPERTY_ID=

# MakeMyTrip
MAKEMYTRIP_API_KEY=
MAKEMYTRIP_PROPERTY_ID=

# ===========================================
# Webhook Secrets - REQUIRED IN PRODUCTION
# ===========================================
BOOKINGCOM_WEBHOOK_SECRET=
AIRBNB_WEBHOOK_SECRET=
AGODA_WEBHOOK_SECRET=
MAKEMYTRIP_WEBHOOK_SECRET=

# ===========================================
# Distributed Lock Settings
# ===========================================
LOCK_TTL_MS=30000
LOCK_RETRY_DELAY_MS=500
LOCK_RETRY_COUNT=3
