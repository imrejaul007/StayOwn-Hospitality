# ===========================================
# StayOwn Hospitality Service - Environment Configuration
# ===========================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT THE .env FILE TO VERSION CONTROL

# ===========================================
# Service Configuration
# ===========================================
PORT=4016
NODE_ENV=development
SERVICE_VERSION=1.0.0

# ===========================================
# CORS
# ===========================================
# Comma-separated list of allowed origins (no spaces)
CORS_ORIGIN=https://admin.rez.money,https://rez.money,https://rez-app.vercel.app

# ===========================================
# Database (MongoDB) - REQUIRED
# ===========================================
MONGODB_URI=mongodb://localhost:27017/rez_stayown
# For Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rez_stayown?authSource=admin
# Optional auth:
# MONGODB_USERNAME=
# MONGODB_PASSWORD=
# MONGODB_AUTH_SOURCE=admin

# ===========================================
# Authentication - REQUIRED IN PRODUCTION
# ===========================================
# Generate a secure secret: openssl rand -base64 64
# JWT secret for token validation (REQUIRED in production)
JWT_SECRET=

# Separate secret for Room QR tokens (recommended)
ROOM_QR_JWT_SECRET=

# Internal service tokens for service-to-service auth (JSON format)
# Generate tokens: openssl rand -hex 32
# Example: {"pms-service":"token1","payment-service":"token2"}
INTERNAL_SERVICE_TOKENS_JSON=

# ===========================================
# Redis (for rate limiting)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Hotel PMS Integration
# ===========================================
# URL of the Hotel PMS service (Hotel OTA)
HOTEL_PMS_URL=http://localhost:3008
HOTEL_OTA_API=http://localhost:3008

# Webhook secret for PMS → StayOwn webhooks
# Must match the secret configured in Hotel-PMS
PMS_WEBHOOK_SECRET=

# ===========================================
# Room QR Configuration
# ===========================================
# Base URL for QR codes
ROOM_QR_BASE_URL=https://rez.money/room

# Webhook secret for Room QR webhooks
ROOM_QR_WEBHOOK_SECRET=

# ===========================================
# WhatsApp Integration
# ===========================================
# App secret for webhook signature verification (REQUIRED in production)
FACEBOOK_APP_SECRET=

WHATSAPP_SERVICE_URL=http://localhost:4004
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ===========================================
# External Services (for notifications)
# ===========================================

# Email Service (for QR notifications)
EMAIL_SERVICE_URL=http://localhost:4003
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rez.money

# SMS Service
SMS_SERVICE_URL=http://localhost:4005

# ===========================================
# ReZ Platform Services
# ===========================================
REZ_AUTH_URL=https://auth.rez.money
REZ_WALLET_URL=https://wallet.rez.money
REZ_ORDER_SERVICE_URL=https://order.rez.money
REZ_PAYMENT_SERVICE_URL=https://payment.rez.money

# ===========================================
# Monitoring
# ===========================================
SENTRY_DSN=
