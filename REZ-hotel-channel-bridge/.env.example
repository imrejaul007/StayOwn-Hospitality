# Server Configuration
PORT=4042
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-hotel-channel-bridge

# Security
INTERNAL_SERVICE_TOKEN=generate-a-secure-token-here

# Redis (optional - for job queue and caching)
REDIS_URL=redis://localhost:6379

# Sync Intervals (in minutes)
INVENTORY_SYNC_INTERVAL=15
PRICING_SYNC_INTERVAL=30
BOOKING_IMPORT_INTERVAL=5

# Sync Settings
SYNC_BATCH_SIZE=100
SYNC_MAX_RETRIES=3
SYNC_RETRY_DELAY=5000

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Webhooks
WEBHOOKS_ENABLED=true
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*
