{
  "name": "hotel-backend",
  "version": "1.0.0",
  "description": "Hotel Management System Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node --max-old-space-size=4096 src/server.js",
    "dev": "nodemon --max-old-space-size=4096 src/server.js",
    "start:prod": "NODE_ENV=production node --max-old-space-size=4096 src/server.js",
    "start:worker": "node src/scripts/start-queue-worker.js",
    "build": "echo 'Backend syntax check...' && node --check src/server.js && echo '✅ Backend build check passed'",
    "build:check": "node -e \"const fs=require('fs'),path=require('path');let e=0,t=0;const walk=(d)=>{for(const f of fs.readdirSync(d,{withFileTypes:true})){const p=path.join(d,f.name);if(f.isDirectory()&&f.name!=='node_modules')walk(p);else if(f.name.endsWith('.js')){t++;try{require('child_process').execSync('node --check '+JSON.stringify(p),{stdio:'pipe'})}catch{console.error('FAIL:',p);e++}}}};walk('src');console.log(t+' files checked, '+e+' errors');process.exit(e)\"",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --coverage --detectOpenHandles",
    "test:unit": "jest src/tests/unit/ --detectOpenHandles --forceExit",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=\"src/tests/integration\" --detectOpenHandles --forceExit",
    "test:integration:gate": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=\"multiProperty.integration\" --detectOpenHandles --forceExit",
    "test:integration:switch-hotel": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=\"switchHotel.integration\" --detectOpenHandles --forceExit --runInBand",
    "test:integration:http": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathPattern=\"(auth.integration|booking.integration)\" --runInBand --detectOpenHandles --forceExit",
    "typecheck": "tsc -p tsconfig.json",
    "check:db": "node src/scripts/check-env-db.js",
    "inspect:base-hotel": "node src/scripts/inspect-base-hotel.js",
    "seed:demo": "node src/scripts/seed-demo-users.js",
    "seed:dashboard": "node src/scripts/seed-dashboard-sample-data.js",
    "seed": "node src/scripts/seed.js",
    "generate-kpis": "node src/scripts/generateKPIs.js",
    "audit:rbac": "node src/scripts/audit-rbac-coverage.js",
    "audit:validation": "node src/scripts/audit-validation-coverage.js",
    "verify:baseline": "node src/scripts/verify-program-baseline.js",
    "profile:api": "node src/scripts/profile-api-performance.js",
    "perf:load:k6": "k6 run src/scripts/load-test.k6.js",
    "queue:health": "node src/scripts/queue-health-snapshot.js",
    "pilot:precheck": "node src/scripts/pilot-precheck.js",
    "pilot:smoke": "node src/scripts/pilot-smoke.js",
    "pms:verify": "node src/scripts/pms-acceptance-verify.js",
    "drill:precheck": "node src/scripts/backup-drill-precheck.js",
    "drill:restore-replay": "node src/scripts/restore-replay-verify.js",
    "migrate": "node src/scripts/migrate.js",
    "migrate:extra-person": "node src/scripts/migrateExtraPersonCharges.js",
    "generate-keys": "node src/scripts/generateKeys.js",
    "optimize-indexes": "node src/scripts/optimizeIndexes.js",
    "test-phase1": "node test-phase1-booking-engine.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "review": "node ../agents/index.js --mode=report-only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.7.0",
    "isomorphic-dompurify": "^2.11.0",
    "joi": "^17.11.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.5",
    "qrcode": "^1.5.4",
    "redis": "^4.6.11",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "stripe": "^14.25.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^11.1.0",
    "validator": "^13.11.0",
    "web-push": "^3.6.6",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.6",
    "@types/node": "^25.5.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/scripts/**",
      "!src/tests/**"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(mongodb-memory-server)/)"
    ]
  }
}
