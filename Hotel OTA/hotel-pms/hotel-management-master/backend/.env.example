# Environment
NODE_ENV=development
PORT=4000

# Database
MONGO_URI=mongodb://localhost:27017/hotel_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_PRIVATE_KEY_PATH=./keys/jwtRS256.key
JWT_PUBLIC_KEY_PATH=./keys/jwtRS256.key.pub

# Stripe Configuration (Get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Redis Configuration
# Method 1: Redis URL (Recommended - works for both local and cloud)
REDIS_URL=redis://localhost:6379

# Method 2: Individual Settings (Alternative configuration)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_DB=0

# Production Redis Settings (for cloud deployments)
# REDIS_TLS=true
# REDIS_TLS_REJECT_UNAUTHORIZED=true

# Example cloud Redis URLs:
# AWS ElastiCache: REDIS_URL=redis://your-cluster.cache.amazonaws.com:6379
# Redis Cloud: REDIS_URL=redis://username:password@redis-12345.c1.us-east1-1.gce.cloud.redislabs.com:12345
# Railway: REDIS_URL=redis://:password@containers-us-west-123.railway.app:6379
# Heroku: REDIS_URL=redis://h:password@ec2-123-123-123-123.compute-1.amazonaws.com:25579

# Email Configuration (Gmail SMTP)
# Generate App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password

# Security
ENCRYPTION_KEY=your_encryption_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional integrations
BOOKINGCOM_CLIENT_ID=your_booking_client_id
BOOKINGCOM_CLIENT_SECRET=your_booking_secret
BOOKINGCOM_API_BASE=https://api.sandbox.booking.com
BOOKINGCOM_REDIRECT_URI=http://localhost:4000/api/v1/ota/booking/callback

GOOGLE_PROJECT_ID=your-gcp-project
GOOGLE_CLOUD_RUN_SERVICE=hotel-backend

# Application URLs
FRONTEND_URL=http://localhost:5173
# Guest app deep links for meet-up notifications (falls back to FRONTEND_URL if unset)
GUEST_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000/api/v1
BASE_URL=http://localhost:4000

# CORS — comma-separated origins allowed to call the API.
# FRONTEND_URL and GUEST_APP_URL are merged automatically (no trailing slash; https in prod).
# On Render with separate static + API services, set FRONTEND_URL to the browser URL of the SPA
# (e.g. https://your-frontend.onrender.com) or list every origin in ALLOWED_ORIGINS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Auth cookies (important for split frontend/API deployments like Render)
# Production default in code is AUTH_COOKIE_SAME_SITE=none, which requires Secure cookies.
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
# Optional: set only if you need to share cookies across subdomains
# AUTH_COOKIE_DOMAIN=.your-domain.com

# API Versioning and Sunset Policy
API_V1_SUNSET_DATE=2027-12-31

# Billing Reconciliation
# false = observe mode (default), true = strict mismatch blocking
BILLING_RECONCILIATION_ENFORCE=false

# Loyalty — stay completion awards (PATCH /bookings/:id/check-out)
# Set LOYALTY_AWARD_ON_CHECKOUT=false to disable automatic earn-on-checkout
LOYALTY_AWARD_ON_CHECKOUT=true
# Points = floor(totalAmount * rate) + floor(nights * perNight), capped at max
LOYALTY_POINTS_PER_CURRENCY_UNIT=0.1
LOYALTY_POINTS_PER_NIGHT=0
LOYALTY_MAX_POINTS_PER_STAY=50000
# Background maintenance (expiry + reconciliation)
LOYALTY_MAINTENANCE_ENABLED=true
LOYALTY_MAINTENANCE_INTERVAL_HOURS=24
LOYALTY_RECON_MAX_USERS=1000
LOYALTY_SLA_MAX_RECON_AGE_HOURS=30
LOYALTY_SLA_MISMATCH_RATE_PCT=2.5
LOYALTY_SLA_DRIFT_SPIKE_COUNT=100
LOYALTY_SLA_EXPIRY_BACKLOG_COUNT=500
LOYALTY_QUEUE_POLL_MS=15000

# Hotel Services hardening
HOTEL_SERVICE_BOOKING_DAILY_LIMIT=10
HOTEL_SERVICE_MAX_FEATURED=12
# Same default tenant as frontend VITE_PUBLIC_DEFAULT_HOTEL_ID (guest JWT may omit hotelId)
PUBLIC_DEFAULT_HOTEL_ID=68cd01414419c17b5f6b4c12

# ReZ Mind Intent Capture (B2B - LOW priority)
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
# Internal service key — must match INTENT_CAPTURE_URL server config
INTERNAL_SERVICE_TOKEN=your-internal-service-token
