# API Configuration
VITE_API_URL=http://localhost:4000/api/v1

# REZ OAuth2 (Partner SSO — must match PARTNER_HOTEL_PMS_* in REZ Auth Service)
VITE_REZ_AUTH_URL=https://rez-auth-service.onrender.com
VITE_REZ_OAUTH_CLIENT_ID=hotel-pms
VITE_REZ_OAUTH_CLIENT_SECRET=change-me-generate-with-openssl-rand-base64-64
VITE_APP_URL=http://localhost:5173

# Public marketing pages (reviews on Home/Reviews) — set per deployment for correct tenant
# VITE_PUBLIC_DEFAULT_HOTEL_ID=

# Stripe Configuration (Get from https://dashboard.stripe.com)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key_here

# App Information
VITE_APP_NAME=Hotel Management System
VITE_APP_VERSION=1.0.0
