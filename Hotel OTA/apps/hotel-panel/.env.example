# Hotel Panel Environment Variables
# Copy this file to .env.local and fill in values

# Hotel OTA API (required)
NEXT_PUBLIC_API_URL=http://localhost:3000/v1

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Redirect URI — must match PARTNER_HOTEL_PANEL_REDIRECT_URI in REZ Auth Service
# Dev: http://localhost:3001/api/auth/callback
# Prod: https://hotel-panel.vercel.app/api/auth/callback
# NOTE: /api/auth/callback is the OAuth2 callback route in this Next.js app

# REZ OAuth2 Partner SSO (must match PARTNER_HOTEL_PANEL_* in REZ Auth Service)
NEXT_PUBLIC_REZ_AUTH_URL=https://rez-auth-service.onrender.com
NEXT_PUBLIC_REZ_OAUTH_CLIENT_ID=hotel-panel
REZ_OAUTH_CLIENT_SECRET=change-me-generate-with-openssl-rand-base64-64
