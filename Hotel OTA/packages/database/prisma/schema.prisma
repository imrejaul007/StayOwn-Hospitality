// ─── UNIFIED CHAT (Cross-platform Support Chat) ──────────────────────────────

model UnifiedChatConversation {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Context
  userId           String    @map("user_id") @db.Uuid
  userName         String    @map("user_name") @db.VarChar(100)
  appType          String    @map("app_type") @db.VarChar(30) // hotel, restaurant, retail, support, general
  merchantId       String?   @map("merchant_id") @db.Uuid
  // Conversation metadata
  type             String    @default("support") @map("type") @db.VarChar(30) // support, order, booking, inquiry
  status           String    @default("active") @map("status") @db.VarChar(20) // active, pending_staff, resolved, closed
  priority         String    @default("normal") @map("priority") @db.VarChar(20) // low, normal, high, urgent
  // Staff assignment
  assignedStaffId  String?   @map("assigned_staff_id") @db.Uuid
  assignedStaffName String?  @map("assigned_staff_name") @db.VarChar(100)
  department       String?   @map("department") @db.VarChar(50)
  // Tracking
  unreadUserCount  Int       @default(0) @map("unread_user_count")
  unreadStaffCount Int       @default(0) @map("unread_staff_count")
  messageCount     Int       @default(0) @map("message_count")
  lastMessage      String?   @map("last_message") @db.VarChar(255)
  lastMessageAt    DateTime? @map("last_message_at") @db.Timestamptz
  // Customer context (JSON for flexibility)
  customerContext  Json?     @map("customer_context") @db.JsonB
  // Timestamps
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz()

  messages UnifiedChatMessage[]

  @@index([userId])
  @@index([appType])
  @@index([merchantId])
  @@index([status])
  @@index([assignedStaffId])
  @@index([createdAt])
  @@map("unified_chat_conversations")
}

model UnifiedChatMessage {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  senderType     String    @map("sender_type") @db.VarChar(20) // user, staff, system, ai
  senderName     String    @map("sender_name") @db.VarChar(100)
  content        String    @db.Text
  messageType    String    @default("text") @map("message_type") @db.VarChar(20) // text, image, file, quick_reply, system
  // Read tracking
  readAt         DateTime? @map("read_at") @db.Timestamptz()
  readBy         String?   @map("read_by") @db.Uuid
  // Metadata (for AI actions, suggestions, etc.)
  metadata       Json?     @map("metadata") @db.JsonB
  // Confidence score (for AI messages)
  aiConfidence   Decimal?  @map("ai_confidence") @db.Decimal(3, 2)
  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  conversation UnifiedChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("unified_chat_messages")
}

// ─── RTMN COMMERCE MEMORY: INTENT GRAPH ───────────────────────────────────────

// Intent: Captures user purchase intent signals
model Intent {
  id            String    @id @default(cuid())
  userId        String    @map("user_id") @db.Uuid
  appType       String    @map("app_type") @db.VarChar(50) // hotel_ota, restaurant, retail, hotel_guest
  category      String    @db.VarChar(20) // TRAVEL, DINING, RETAIL, HOTEL_SERVICE, GENERAL
  intentKey     String    @map("intent_key") @db.VarChar(255) // e.g., "hotel_goa_weekend"
  intentQuery   String?   @map("intent_query") @db.VarChar(500)
  confidence    Decimal   @db.Decimal(3, 2) @default(0.30)
  status        String    @default("ACTIVE") @db.VarChar(20) // ACTIVE, DORMANT, FULFILLED, EXPIRED
  firstSeenAt   DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz()
  lastSeenAt    DateTime  @updatedAt @map("last_seen_at") @db.Timestamptz()

  signals        IntentSignal[]
  dormantIntents DormantIntent[]
  sequences      IntentSequence[]

  @@unique([userId, appType, intentKey])
  @@index([userId, status])
  @@index([status, lastSeenAt])
  @@index([category, status])
  @@index([appType, category])
  @@map("intents")
}

// IntentSignal: Individual events that contribute to intent confidence
model IntentSignal {
  id          String    @id @default(cuid())
  intentId    String    @map("intent_id") @db.Uuid
  eventType   String    @map("event_type") @db.VarChar(30) // search, view, wishlist, cart_add, hold, checkout_start, fulfilled, abandoned
  weight      Decimal   @db.Decimal(3, 2)
  data        Json?     @db.JsonB
  capturedAt  DateTime  @default(now()) @map("captured_at") @db.Timestamptz()

  intent Intent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([intentId])
  @@index([eventType, capturedAt])
  @@index([intentId, capturedAt])
  @@map("intent_signals")
}

// DormantIntent: Intents that have gone cold and are candidates for revival
model DormantIntent {
  id              String    @id @default(cuid())
  intentId        String    @map("intent_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  appType         String    @map("app_type") @db.VarChar(50)
  category        String    @db.VarChar(20)
  intentKey       String    @map("intent_key") @db.VarChar(255)
  dormancyScore   Decimal   @db.Decimal(4, 3) @default(0.500)
  revivalScore    Decimal   @db.Decimal(4, 3) @default(0.000)
  daysDormant     Int       @map("days_dormant") @default(0)
  lastNudgeSent   DateTime? @map("last_nudge_sent") @db.Timestamptz()
  nudgeCount      Int       @map("nudge_count") @default(0)
  idealRevivalAt  DateTime? @map("ideal_revival_at") @db.Timestamptz()
  status          String    @default("active") @db.VarChar(20) // active, paused, revived
  revivedAt       DateTime? @map("revived_at") @db.Timestamptz()

  intent Intent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@unique([userId, appType, intentKey])
  @@index([userId, status])
  @@index([status, revivalScore])
  @@index([idealRevivalAt])
  @@map("dormant_intents")
}

// IntentSequence: Tracks the order of events in an intent journey
model IntentSequence {
  id            String    @id @default(cuid())
  intentId      String    @map("intent_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  eventType     String    @map("event_type") @db.VarChar(30)
  sequenceOrder Int       @map("sequence_order")
  durationMs    Int?      @map("duration_ms")
  occurredAt    DateTime  @default(now()) @map("occurred_at") @db.Timestamptz()

  intent Intent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([intentId, sequenceOrder])
  @@index([userId, occurredAt])
  @@map("intent_sequences")
}

// CrossAppIntentProfile: Aggregated cross-app intent profile for a user
model CrossAppIntentProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique @map("user_id") @db.Uuid
  travelIntentCount   Int       @map("travel_intent_count") @default(0)
  diningIntentCount  Int       @map("dining_intent_count") @default(0)
  retailIntentCount  Int       @map("retail_intent_count") @default(0)
  dormantTravelCount Int       @map("dormant_travel_count") @default(0)
  dormantDiningCount Int       @map("dormant_dining_count") @default(0)
  dormantRetailCount Int       @map("dormant_retail_count") @default(0)
  totalConversions   Int       @map("total_conversions") @default(0)
  travelAffinity    Int       @map("travel_affinity") @default(50)
  diningAffinity    Int       @map("dining_affinity") @default(50)
  retailAffinity    Int       @map("retail_affinity") @default(50)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([travelAffinity])
  @@index([diningAffinity])
  @@index([totalConversions])
  @@map("cross_app_intent_profiles")
}

// Nudge: Record of nudge messages sent to users
model Nudge {
  id               String    @id @default(cuid())
  dormantIntentId  String    @map("dormant_intent_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  channel          String    @db.VarChar(20) // push, email, sms, in_app
  message          String    @db.Text
  status           String    @default("pending") @db.VarChar(20) // pending, sent, delivered, clicked, converted, failed
  sentAt           DateTime? @map("sent_at") @db.Timestamptz()
  deliveredAt      DateTime? @map("delivered_at") @db.Timestamptz()
  clickedAt        DateTime? @map("clicked_at") @db.Timestamptz()
  convertedAt      DateTime? @map("converted_at") @db.Timestamptz()
  error            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([dormantIntentId])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([channel, status])
  @@map("nudges")
}

// ─── MERCHANT KNOWLEDGE BASE ───────────────────────────────────────────────

// MerchantKnowledge: Stores merchant knowledge for autonomous chat
model MerchantKnowledge {
  id          String    @id @default(cuid())
  merchantId  String    @map("merchant_id") @db.VarChar(100)
  type        String    @db.VarChar(50) // menu, policy, faq, offer, hours, contact, custom
  title       String    @db.VarChar(255)
  content     String    @db.Text
  tags        String[]  @db.VarChar(50)
  metadata    Json?     @db.JsonB
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([merchantId, active])
  @@index([type, merchantId])
  @@map("merchant_knowledge")
}

// ─── ROOM BUNDLES ─────────────────────────────────────────────────

model HotelBundle {
  id               String   @id @default(cuid())
  hotelId          String   @map("hotel_id")
  name             String   @db.VarChar(255)
  description      String?
  roomTypeIds      String[] @map("room_type_ids")
  basePricePaise   Int      @map("base_price_paise")
  pricePaise      Int?     @map("price_paise")
  originalPricePaise Int?   @map("original_price_paise")
  discountPct      Int      @default(0) @map("discount_pct")
  category         String?  @db.VarChar(100)
  services         String?  @db.Text
  duration         Int?     @map("duration")
  badges           String?  @db.Text
  amenities        String[] @default([])
  images           String[] @default([])
  isActive         Boolean  @default(true) @map("is_active")
  isPopular        Boolean  @default(false) @map("is_popular")
  isAiSuggested    Boolean  @default(false) @map("is_ai_suggested")
  suggestedReason  String?  @map("suggested_reason") @db.Text
  available        Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  orders BundleOrder[]

  @@map("hotel_bundles")
}

model BundleOrder {
  id              String    @id @default(cuid())
  bundleId        String    @map("bundle_id")
  bundleName     String?   @map("bundle_name") @db.VarChar(255)
  userId          String    @map("user_id")
  hotelId         String    @map("hotel_id")
  bookingId       String?   @map("booking_id")
  roomId          String?   @map("room_id")
  checkInDate     DateTime  @map("check_in_date") @db.Date
  checkOutDate    DateTime  @map("check_out_date") @db.Date
  scheduledFor    DateTime? @map("scheduled_for") @db.Timestamptz()
  guestName       String?   @map("guest_name") @db.VarChar(255)
  guestPhone      String?   @map("guest_phone") @db.VarChar(15)
  totalPricePaise Int       @map("total_price_paise")
  totalAmountPaise Int?     @map("total_amount_paise")
  status          String    @default("pending") @db.VarChar(20)
  notes           String?   @map("notes") @db.Text
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()
  razorpayOrderId String?   @map("razorpay_order_id") @db.VarChar(255)
  razorpayPaymentId String? @map("razorpay_payment_id") @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  bundle HotelBundle @relation(fields: [bundleId], references: [id])

  @@index([userId])
  @@index([hotelId])
  @@index([bundleId])
  @@map("bundle_orders")
}

// ─── ROOM SERVICES ─────────────────────────────────────────────

model MinibarConsumption {
  id          String    @id @default(cuid())
  bookingId   String    @map("booking_id")
  hotelId    String    @map("hotel_id")
  roomId     String    @map("room_id")
  itemId     String?   @map("item_id") @db.VarChar(100)
  items      Json
  totalPaise Int       @map("total_paise")
  pricePaise Int?      @map("price_paise")
  quantity   Int?      @default(1)
  isCharged  Boolean   @default(false) @map("is_charged")
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz()
  status     String    @default("pending") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([hotelId])
  @@map("minibar_consumptions")
}

model GuestFeedback {
  id              String   @id @default(cuid())
  bookingId       String   @map("booking_id")
  hotelId        String   @map("hotel_id")
  roomId         String   @map("room_id")
  guestUserId    String?  @map("guest_user_id")
  serviceType     String  @map("service_type") @db.VarChar(50)
  rating         Int
  overallRating  Int?     @map("overall_rating")
  cleanlinessRating Int? @map("cleanliness_rating")
  serviceRating  Int?     @map("service_rating")
  amenitiesRating Int?    @map("amenities_rating")
  comfortRating  Int?     @map("comfort_rating")
  comment        String?
  issues         Json?
  wouldRecommend Boolean? @map("would_recommend")
