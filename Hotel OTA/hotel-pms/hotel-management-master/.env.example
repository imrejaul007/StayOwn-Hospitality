# Docker Compose Environment Variables
# Copy this to .env and fill in your values

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_secure_password_here
MONGO_INITDB_DATABASE=hotel_management

# JWT
JWT_SECRET=your_jwt_secret_at_least_32_chars_here
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key

# Security
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development

# App
VITE_APP_NAME=Hotel Management System

# ReZ Mind Intent Capture (B2B - LOW priority)
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# REZ OAuth2 Partner SSO (must match PARTNER_HOTEL_PMS_* in REZ Auth Service)
# Generate client secret with: openssl rand -base64 64
VITE_REZ_AUTH_URL=https://rez-auth-service.onrender.com
VITE_REZ_OAUTH_CLIENT_ID=hotel-pms
VITE_REZ_OAUTH_CLIENT_SECRET=change-me-generate-with-openssl-rand-base64-64
# Redirect URI — must match PARTNER_HOTEL_PMS_REDIRECT_URI in REZ Auth Service
# Dev: http://localhost:5173/auth/rez-callback
# Prod: https://your-hotel-pms-domain.com/auth/rez-callback
# NOTE: /auth/rez-callback is the client-side OAuth callback route in hotel-pms React Router
VITE_REZ_OAUTH_REDIRECT_URI=http://localhost:5173/auth/rez-callback
