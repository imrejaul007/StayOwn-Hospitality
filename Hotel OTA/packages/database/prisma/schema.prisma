  createdAt      DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([hotelId])
  @@map("guest_feedbacks")
}

model RoomPreferences {
  id                   String   @id @default(cuid())
  userId               String  @map("user_id")
  guestUserId         String? @map("guest_user_id")
  hotelId             String  @map("hotel_id")
  roomId               String? @map("room_id")
  roomTypeId          String? @map("room_type_id")
  preferences         Json
  temperature         String? @db.VarChar(20)
  lighting            String? @db.VarChar(50)
  pillowType          String? @db.VarChar(50)
  dietaryRestrictions Json?
  dietaryNeeds        String[] @default([]) @map("dietary_needs")
  allergies           Json?
  language            String?  @db.VarChar(50)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([userId, hotelId])
  @@map("room_preferences")
}

model HotelService {
  id           String   @id @default(cuid())
  hotelId     String   @map("hotel_id")
  name        String   @db.VarChar(255)
  serviceName String?  @map("service_name") @db.VarChar(255)
  category    String   @db.VarChar(100)
  description String?
  pricePaise  Int      @map("price_paise")
  isActive    Boolean  @default(true) @map("is_active")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  serviceConfig Json?  @map("service_config") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([hotelId])
  @@index([category])
  @@map("hotel_services")
}

model StaffInvite {
  id          String    @id @default(cuid())
  hotelId    String    @map("hotel_id")
  email      String    @db.VarChar(255)
  name       String?   @db.VarChar(255)
  phone      String?   @db.VarChar(15)
  role       String    @default("staff") @db.VarChar(50)
  inviteToken String   @unique @map("invite_token") @db.VarChar(255)
  status     String    @default("pending") @db.VarChar(20)
  invitedBy  String?   @map("invited_by")
  acceptedAt DateTime? @map("accepted_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@index([email])
  @@map("staff_invites")
}

model Room {
  id         String   @id @default(cuid())
  hotelId    String   @map("hotel_id")
  roomTypeId String   @map("room_type_id")
  roomNumber String   @map("room_number") @db.VarChar(20)
  floor      String?  @db.VarChar(10)
  status     String   @default("available") @db.VarChar(20)
  isActive   Boolean  @default(true) @map("is_active")
  amenities  String[] @default([]) @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  hotel          Hotel                @relation(fields: [hotelId], references: [id])
  roomType       RoomType             @relation(fields: [roomTypeId], references: [id])
  serviceRequests RoomServiceRequest[]

  @@unique([hotelId, roomNumber])
  @@index([hotelId])
  @@index([status])
  @@map("rooms")
}

model StaffNotification {
  id        String   @id @default(cuid())
  staffId   String   @map("staff_id")
  hotelId   String   @map("hotel_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String   @db.Text
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([staffId, isRead])
  @@index([hotelId])
  @@map("staff_notifications")
}
