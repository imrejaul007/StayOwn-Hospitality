# ===========================================
# Verify Service - Environment Configuration
# ===========================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT THE .env FILE TO VERSION CONTROL

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/verify_db"

# ===========================================
# Authentication - REQUIRED IN PRODUCTION
# ===========================================
# Generate: openssl rand -base64 64
JWT_SECRET=""

# Internal Service Key for service-to-service auth
INTERNAL_SERVICE_KEY=""

# ===========================================
# ReZ Platform Services
# ===========================================
WALLET_API_URL="http://localhost:3001"
AUTH_API_URL="http://localhost:3002"
KARMA_API_URL="http://localhost:4001"

# ===========================================
# ReZ Mind (AI Intelligence) - REQUIRED
# ===========================================
# Event tracking platform for user behavior analysis
REZ_MIND_URL="https://rez-mind.onrender.com"

# ReZ Intent Graph - tracks user purchase intent across ReZ ecosystem
INTENT_CAPTURE_URL="https://rez-intent-graph.onrender.com"

# ===========================================
# WhatsApp Integration
# ===========================================
WHATSAPP_API_URL="https://graph.facebook.com/v18.0"
WHATSAPP_ACCESS_TOKEN=""

# ===========================================
# External Services
# ===========================================
# Claude API for fraud analysis (optional)
ANTHROPIC_API_KEY=""

# Redis for caching
REDIS_URL="redis://localhost:6379"

# QR Code Generation API (optional)
QR_API_KEY=""
