# Hotel OTA (StayOwn) — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.

# ── API ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/v1

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003

# ── REZ OAuth2 (Partner SSO) ─────────────────────────────────────────────────
# OAuth2 credentials for REZ Auth Service integration.
# Register at: REZ Auth Service admin
NEXT_PUBLIC_REZ_AUTH_URL=https://rez-auth-service.onrender.com
NEXT_PUBLIC_REZ_OAUTH_CLIENT_ID=stay-owen
REZ_OAUTH_CLIENT_SECRET=generate_with_openssl_rand_hex_32

# ── Hotel Panel ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_HOTEL_PANEL_URL=http://localhost:3002
