# Server
PORT=4006
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-channel-manager

# Redis
REDIS_URL=redis://localhost:6379

# Internal Service Communication
INTERNAL_SERVICE_TOKENS_JSON={"pms-service":"pms-token","payment-service":"payment-token"}

# Channel API Credentials
BOOKINGCOM_API_KEY=
BOOKINGCOM_API_SECRET=
BOOKINGCOM_PROPERTY_ID=

AIRBNB_API_KEY=
AIRBNB_PROPERTY_ID=

AGODA_API_KEY=
AGODA_PROPERTY_ID=

MAKEMYTRIP_API_KEY=
MAKEMYTRIP_PROPERTY_ID=

# Webhook Secrets
BOOKINGCOM_WEBHOOK_SECRET=
AIRBNB_WEBHOOK_SECRET=
AGODA_WEBHOOK_SECRET=
MAKEMYTRIP_WEBHOOK_SECRET=

# Distributed Lock Settings
LOCK_TTL_MS=30000
LOCK_RETRY_DELAY_MS=500
LOCK_RETRY_COUNT=3
