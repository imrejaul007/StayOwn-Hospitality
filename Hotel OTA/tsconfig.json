{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "exclude": [
    "node_modules",
    "dist",
    "hotel-pms/**/*",
    "apps/admin/**/*",
    "apps/hotel-panel/**/*",
    "apps/ota-web/**/*",
    "apps/corporate-panel/**/*",
    "apps/mobile/**/*"
  ]
}
